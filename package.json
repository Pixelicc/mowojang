{
  "name": "mowojang",
  "version": "0.4.6-dev.0",
  "description": "A simple JavaScript and TypeScript compatible wrapper for the Mowojang-API.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "node test test/index.js",
    "prettier:check": "pnpm dlx prettier . --check",
    "prettier:write": "pnpm dlx prettier . --write",
    "prepare": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pixelicc/mowojang"
  },
  "keywords": [
    "Minecraft",
    "Mowojang",
    "Wrapper",
    "API"
  ],
  "author": "Pixelic",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": { 
    "axios": "^1.16.1",
    "axios-cache-interceptor": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@pixelic/logger": "npm:@jsr/pixelic__logger@^0.0.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
